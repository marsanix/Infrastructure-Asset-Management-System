# ============================================================
# IAMS Environment Variables — COPY ke .env dan isi nilainya
# JANGAN commit file .env ke git!
# ============================================================

# Flask
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-64-char-string

# JWT
JWT_SECRET_KEY=change-this-to-another-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=iams_db
POSTGRES_USER=iams_user
POSTGRES_PASSWORD=change-this-strong-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-redis-password

# AES Encryption Key (untuk asset credentials) — 32 bytes base64
AES_ENCRYPTION_KEY=change-this-to-32-byte-base64-key=

# Rate Limiting
RATELIMIT_DEFAULT=200 per day;50 per hour
RATELIMIT_LOGIN=10 per minute

# CORS — pisahkan dengan koma jika lebih dari satu origin
CORS_ORIGINS=http://localhost:5173

# Admin default (hanya untuk seeding pertama kali)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-admin-password
